    {
      "name": "Authentication",
      "description": "Login sets the `dicto_session` cookie in Postman's cookie jar.",
      "item": [
        {
          "name": "Login as User",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "url": "{{baseUrl}}/api/auth/login",
            "description": "Authenticates with the default regular user and stores the session cookie.",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{userEmail}}\",\n  \"password\": \"{{userPassword}}\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Status code is 200\", function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test(\"Authenticated user is returned\", function () {",
                  "  const response = pm.response.json();",
                  "  pm.expect(response).to.have.property(\"user\");",
                  "  pm.expect(response.user.email).to.eql(pm.collectionVariables.get(\"userEmail\"));",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Login as Admin",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "url": "{{baseUrl}}/api/auth/login",
            "description": "Authenticates with the default admin and replaces the active session cookie.",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{adminEmail}}\",\n  \"password\": \"{{adminPassword}}\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Status code is 200\", function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test(\"Authenticated user is an admin\", function () {",
                  "  const response = pm.response.json();",
                  "  pm.expect(response.user.is_admin).to.eql(true);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Google Sign-In",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "url": "{{baseUrl}}/api/auth/google",
            "description": "Authenticates with a Google ID token. Requires `GOOGLE_CLIENT_ID` on the backend.",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"credential\": \"{{googleCredential}}\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          },
          "response": []
        },
        {
