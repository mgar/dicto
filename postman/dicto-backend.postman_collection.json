                  "  pm.response.to.have.status(200);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Get Review Queue",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/api/reviews/queue?limit=20&kind={{kind}}",
            "description": "Returns reviews due now. The test captures the first prompt ID when available."
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Status code is 200\", function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "const response = pm.response.json();",
                  "const items = Array.isArray(response) ? response : (response.items || response.queue || []);",
                  "if (items.length && items[0].id) {",
                  "  pm.collectionVariables.set(\"reviewPromptId\", items[0].id);",
                  "} else if (items.length && items[0].prompt_id) {",
                  "  pm.collectionVariables.set(\"reviewPromptId\", items[0].prompt_id);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Submit Review Answer",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "url": "{{baseUrl}}/api/reviews/{{reviewPromptId}}/answer",
            "description": "Submit an answer for a due prompt. Adjust `user_answer` to match the selected prompt.",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"user_answer\": \"es\",\n  \"local_date\": \"{{localDate}}\",\n  \"tz_offset\": \"{{tzOffset}}\",\n  \"time_zone\": \"{{timeZone}}\"\n}",
