# Copy to `.env` for docker-compose (required for `env_file` entries in compose).
# Use a single hostname for the UI and API in the browser (e.g. localhost). Mixing
# `localhost` and `127.0.0.1` breaks session cookies and CORS with API_CORS_ORIGIN.
# Database: MySQL only. If DATABASE_URL is unset, values below are used (docker-compose).
# Optional DATABASE_URL for hosted MySQL (e.g. Aiven): mysql+pymysql://USER:PASS@HOST:PORT/DB?charset=utf8mb4
# For Aiven TLS, set MYSQL_SSL_REQUIRE=true (see backend app/db/database.py).
MYSQL_SSL_REQUIRE=false

MYSQL_DATABASE=dicto
MYSQL_USER=dicto
MYSQL_PASSWORD=dicto_pass
MYSQL_ROOT_PASSWORD=root_pass

# API
API_CORS_ORIGIN=http://localhost:5173
# Split HTTPS origins (e.g. static site + API on different hosts): use true + none.
SESSION_COOKIE_SECURE=false
SESSION_COOKIE_SAMESITE=lax

# Frontend
VITE_API_BASE_URL=http://localhost:8000

DEFAULT_USER_EMAIL=test@dicto.es
DEFAULT_USER_PASSWORD=changeme
DEFAULT_ADMIN_EMAIL=admin@dicto.es
DEFAULT_ADMIN_PASSWORD=changeme

# Google Sign-In
GOOGLE_CLIENT_ID=501219618717-in577r8s98a2inaqrhaboqe7o22an5fv.apps.googleusercontent.com
VITE_GOOGLE_CLIENT_ID=501219618717-in577r8s98a2inaqrhaboqe7o22an5fv.apps.googleusercontent.com
